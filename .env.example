# ========================================
# 環境變數範本：複製成 .env 後填入真實值
# Railway 部署時把這些變數設到專案 Variables 頁
# ========================================

# Telegram Bot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail（OAuth 用，需搭配 credentials.json + token.pickle）
GMAIL_USER=
PDF_PASSWORD_PREFIX=

# 雲端用：本機 OAuth 拿到 token.pickle 後，執行 `base64 -w 0 token.pickle` 產出貼這
TOKEN_PICKLE_B64=

# 追蹤股票（逗號分隔，台股用代號、美股用 ticker）
MANUAL_STOCKS=2330,AAPL,TSLA

# 天氣地點（逗號分隔，需符合 CWA 鄉鎮名）
WEATHER_LOCATIONS=淡水區,金山區

# 中央氣象署 https://opendata.cwa.gov.tw/
CWA_API_KEY=

# OpenWeatherMap https://openweathermap.org/api
OWM_API_KEY=

# Anthropic Claude https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 預留欄位（目前實際排程在 railway.json 的 cronSchedule）
SCHEDULE_UTC=23:00
